@baseUrl = http://localhost:4001/api/v1

### 1. Register User (สมัครสมาชิก)
POST {{baseUrl}}/users/register
Content-Type: application/json

{
    "username": "jamine_admin",
    "email": "admin@example.com",
    "password": "password123",
    "confirmPassword": "password123"
}

### 2. Login User (เข้าสู่ระบบ)
POST {{baseUrl}}/users/login
Content-Type: application/json

{
    "email": "admin@example.com",
    "password": "password123"
}

### 3. Get All Users (เฉพาะ Admin)
# ต้อง Login ก่อน และต้องเป็น Admin
GET {{baseUrl}}/users

### 4. Get Single User (ต้อง Login)
# แทนที่ :id ด้วย ID จริง (ถ้ากดยิงเองใน VS Code)
@userId = 664d1234567890abcdef1234
GET {{baseUrl}}/users/{{userId}}

### 5. Update User (ต้อง Login)
PUT {{baseUrl}}/users/{{userId}}
Content-Type: application/json

{
    "username": "jamine_updated",
    "role": "admin"
}

### 6. Delete User (เฉพาะ Admin)
DELETE {{baseUrl}}/users/{{userId}}

### 7. Logout User (ออกจากระบบ)
# ย้ายมาไว้ท้ายสุดเพื่อให้ Test อื่นๆ ทำงานได้ก่อน
POST {{baseUrl}}/users/logout
