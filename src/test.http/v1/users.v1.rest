### 4.5 Get My Profile (ดูโปรไฟล์ตัวเอง)
# ต้อง Login ก่อน (จะ Admin หรือ User ก็ได้)
GET {{baseUrl}}/users/me



### 5. Get All Users (เฉพาะ Admin)
# ต้อง Login ด้วย Admin เท่านั้น
GET {{baseUrl}}/users






### 6. Get Single User (ต้อง Login)
# แทนที่ :id ด้วย ID จริงที่ได้จากตอนสมัครหรือ Login
@userId = 6a1068e8fec96774ab5ea603
GET {{baseUrl}}/users/{{userId}}



### 7. Update User (ต้อง Login)
PUT {{baseUrl}}/users/{{userId}}
Content-Type: application/json

{
    "username": "jamine_updated11"
}



### 8. Delete User (ปิดไว้ชั่วคราว)
# DELETE {{baseUrl}}/users/{{userId}}

### 9. Logout User (ออกจากระบบ)
POST {{baseUrl}}/users/logout
