@baseUrl = http://localhost:4001/api/v1

### 1. Login as Admin
# @name adminLogin
POST {{baseUrl}}/users/login
Content-Type: application/json

{
    "email": "admin@example.com",
    "password": "password123"
}

### 2. Get Dashboard All (Combined Data)
GET {{baseUrl}}/admin/dashboard/all

### 3. Get Dashboard Summary
GET {{baseUrl}}/admin/dashboard/summary?period=month

### 4. Get Revenue Chart
GET {{baseUrl}}/admin/dashboard/revenue-chart?period=month

### 5. Get Category Sales
GET {{baseUrl}}/admin/dashboard/category-sales?period=year

### 6. Get Recent Orders
GET {{baseUrl}}/admin/dashboard/recent-orders?limit=3

### 7. Get Top Products
GET {{baseUrl}}/admin/dashboard/top-products?limit=3

### 8. Get Low Stock Products
GET {{baseUrl}}/admin/dashboard/low-stock?threshold=10

### 9. Get Order Status Distribution
GET {{baseUrl}}/admin/dashboard/order-status

### 10. Get User Growth Chart
GET {{baseUrl}}/admin/dashboard/user-growth?period=year
