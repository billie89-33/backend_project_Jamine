@baseUrl = http://localhost:4001/api/v1

### 1. Login as Admin
# @name adminLogin
POST {{baseUrl}}/users/login
Content-Type: application/json

{
    "email": "admin@example.com",
    "password": "password123"
}

### 2. Create New Product - Integrated Upload (Admin Only)
# @name createProduct
POST {{baseUrl}}/admin/products
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW

------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="brand"

MSI
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="modelName"

Katana 15
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="description"

Powerful gaming laptop with RTX 4060 and 13th Gen Intel Core i7.
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="price"

45900
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="sku"

MSI-KATANA-15-B13V
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="category"

Notebook
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="stock"

20
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="specifications"

{"CPU": "Intel Core i7-13620H", "GPU": "RTX 4060", "RAM": "16GB"}
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="image"; filename="product-sample-1.png"
Content-Type: image/png

< ../../test-images/product-sample-1.png
------WebKitFormBoundary7MA4YWxkTrZu0gW--

