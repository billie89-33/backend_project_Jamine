# จงใจส่ง SKU เดิมเพื่อให้เกิด Database Error และทดสอบว่าระบบลบรูปใน Cloudinary หรือไม่
POST {{baseUrl}}/admin/products
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW

------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="brand"

MSI-Duplicate
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="sku"

MSI-KATANA-15-B13V
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="image"; filename="product-sample-2.png"
