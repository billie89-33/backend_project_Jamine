@baseUrl = http://localhost:4001/api/v1

### 1. Login as Admin (ต้องเป็นแอดมินเพื่อสร้าง/แก้ไขสินค้า)
# @name adminLogin
POST {{baseUrl}}/users/login
Content-Type: application/json

{
    "email": "admin123@example.com",
    "password": "password123"
}

### 2. Get All Products (Public)
GET {{baseUrl}}/products

### 2.1 Get Products by Category (Filter: Notebook)
GET {{baseUrl}}/products?category=Notebook

### 2.2 Get Products by Category (Filter: Keyboard)
GET {{baseUrl}}/products?category=Keyboard

### 3. Create New Product - Asus (Admin Only)
# ต้องแนบ image object (url, publicId) ไปด้วยเสมอตาม Model ใหม่
POST {{baseUrl}}/products
Content-Type: application/json

{
    "brand": "Asus",
    "modelName": "ROG Zephyrus G16",
    "price": 69900,
    "sku": "ASUS-ROG-G16-999",
    "category": "Notebook",
    "stock": 15,
    "image": {
        "url": "https://res.cloudinary.com/jamine/image/upload/v12345/products/asus-g16.jpg",
        "publicId": "products/asus-g16"
    },
    "specifications": {
        "CPU": "Intel Core i9",
        "GPU": "RTX 4080",
        "RAM": "32GB"
    }
}

