@baseUrl = http://localhost:4001/api/v1

### 1. Login as Admin (ต้องเป็นแอดมินเพื่อสร้าง/แก้ไขสินค้า)
POST {{baseUrl}}/users/login
Content-Type: application/json

{
    "email": "admin123@example.com",
    "password": "password123"
}

### 2. Get All Products (Public)
GET {{baseUrl}}/products

### 3. Create New Product (Admin Only)
POST {{baseUrl}}/products
Content-Type: application/json

{
    "brand": "Asus",
    "modelName": "ROG Zephyrus G16",
    "price": 69900,
    "sku": "ASUS-ROG-G16-999",
    "category": "Notebook",
    "specifications": {
        "CPU": "Intel Core i9",
        "GPU": "RTX 4080",
        "RAM": "32GB"
    }
}

