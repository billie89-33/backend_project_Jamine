generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String   @id @default(uuid())
  username       String   @unique
  name           String?
  phone          String?
  avatarPublicId String?
  avatarUrl      String?
  role           String   @default("user")
  status         String   @default("active")
  email          String   @unique
  password       String
  addresses      Json?    // Array of addresses stored as JSON
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orders Order[]
  cart   Cart?
}

model Product {
  id             String   @id @default(uuid())
  brand          String
  modelName      String
  description    String
  price          Int
  imageUrl       String
  imagePublicId  String
  sku            String   @unique
  category       String
  tags           String[]
  stock          Int      @default(0)
  status         String   @default("ACTIVE")
  isFeatured     Boolean  @default(false)
  soldCount      Int      @default(0)
  viewCount      Int      @default(0)
  specifications Json?    // Dynamic fields (Map of String in Mongoose)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orderItems OrderItem[]
  cartItems  CartItem[]
}

model Order {
  id                   String   @id @default(uuid())
  orderNumber          String   @unique
  userId               String
  user                 User     @relation(fields: [userId], references: [id])
  shippingAddress      Json     // Snapshot of address at purchase
  subtotal             Int
  shippingFee          Int
  total                Int
  status               String   @default("PENDING")
  paymentMethod        String?
  paymentPaidAt        DateTime?
  paymentTransactionId String?
  expiresAt            DateTime
  trackingNumber       String?
  shippedAt            DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  items OrderItem[]
}

model OrderItem {
  id              String  @id @default(uuid())
  orderId         String
  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product @relation(fields: [productId], references: [id])
  brand           String  // Snapshot
  modelName       String  // Snapshot
  image           String  // Snapshot
  quantity        Int
  priceAtPurchase Int     // Snapshot
}

model Cart {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtotal    Int      @default(0)
  shippingFee Int      @default(0)
  total       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items CartItem[]
}

model CartItem {
  id        String  @id @default(uuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)

  @@unique([cartId, productId]) // A cart shouldn't have duplicate product rows, just increase quantity
}

model NewsCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  news News[]
}

model News {
  id            String       @id @default(uuid())
  title         String
  content       String
  categoryId    String
  category      NewsCategory @relation(fields: [categoryId], references: [id])
  imagePublicId String?
  imageUrl      String
  author        String       @default("Admin")
  isPublished   Boolean      @default(true)
  views         Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model CategoryMeta {
  id            String   @id @default(uuid())
  categoryName  String   @unique
  imageUrl      String
  imagePublicId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Banner {
  id            String   @id @default(uuid())
  title         String
  imageUrl      String
  imagePublicId String
  linkUrl       String   @default("")
  placement     String
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
